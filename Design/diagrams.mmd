%% ============================================================
%% 3. ORDER PLACEMENT — END-TO-END SEQUENCE
%% ============================================================
sequenceDiagram
    actor C as Client
    participant API as Command API
    participant DB as PostgreSQL (orders + outbox)
    participant CDC as Eventuate CDC
    participant K as Kafka
    participant SG as PlaceOrderSaga
    participant INV as Inventory / Billing / Fulfilment
    participant PR as OrderProjector
    participant M as MongoDB

    C->>API: POST /v1/orders (Idempotency-Key)
    API->>DB: insert Order (PLACED) + OrderPlaced event — one tx
    API-->>C: 202 Accepted {orderId}
    Note over C,M: GET before projection lands → served from DB (read-your-writes)
    CDC->>DB: poll outbox (published = 0)
    CDC->>K: publish OrderPlaced + saga commands
    K->>SG: drive saga
    SG->>INV: hold inventory / billing / fulfil (per billingMode — DD-23)
    INV-->>SG: replies
    SG->>DB: confirmOrder → status CONFIRMED + OrderConfirmed event (one tx)
    SG->>DB: completeOrder → status COMPLETED + OrderCompleted event (after fulfil)
    K->>PR: OrderPlaced / OrderConfirmed / OrderCompleted
    PR->>M: upsert orders_v1 / entitlements_v1


%% ============================================================
%% 4. PLACEORDERSAGA — STATE MACHINE
%% ============================================================
%% Two flows by billingMode (DD-23); pivot = last compensatable step
%% (commit for PAY_NOW, appendLedger for BILL_TO_MOBILE). confirm onward is forward-only.
%% DD-24: PAY_NOW captures BEFORE fulfil; a hard capture decline parks at CAPTURE_FAILED.
stateDiagram-v2
    [*] --> Placed

    state "PAY_NOW" as PayNow {
        Placed --> Reserving : start
        Reserving --> Authorizing : InventoryReserved
        Reserving --> FailNoComp1 : ReservationFailed
        Authorizing --> Committing : BillingAuthorized
        Authorizing --> CompReserve : BillingDeclined
        Committing --> Confirmed_PN : InventoryCommitted (PIVOT)
        CompReserve --> Failed_PN : InventoryReleased
        FailNoComp1 --> Failed_PN : terminal
    }

    state "BILL_TO_MOBILE" as Postpaid {
        Placed2 : Placed
        [*] --> Placed2
        Placed2 --> CheckingLimit : start
        CheckingLimit --> Allocating : AccountLimitOk
        CheckingLimit --> FailNoComp2 : AccountLimitExceeded
        Allocating --> Appending : InventoryAllocated
        Allocating --> FailNoComp2 : AllocationFailed
        Appending --> Confirmed_BM : LedgerAppended (PIVOT)
        Appending --> CompAllocate : LedgerFailed
        CompAllocate --> Failed_BM : InventoryReleased
        FailNoComp2 --> Failed_BM : terminal
    }

    Confirmed_PN --> Capturing : confirm (forward-only)
    Confirmed_BM --> Fulfilling : confirm (forward-only)
    Capturing --> Fulfilling : BillingCaptured (PAY_NOW)
    Capturing --> CaptureFailed : BillingCaptureFailed (hard decline)
    Fulfilling --> Completed : OrderFulfilled
    Completed --> [*]
    CaptureFailed --> [*]
    Failed_PN --> [*]
    Failed_BM --> [*]


%% ============================================================
%% 5. OIDC LOGIN FLOW  (subscriber → OTT)
%% ============================================================
sequenceDiagram
    participant U as Subscriber
    participant OTT as OTT Platform (RP)
    participant GW as Gateway (OP)

    U->>OTT: open OTT app
    OTT->>U: redirect to /oidc/authorize?client_id=ott&code_challenge=...&scope=openid profile
    U->>GW: GET /oidc/authorize (with PKCE code challenge)
    GW->>U: login screen (subscriber credentials)
    U->>GW: submit credentials
    GW-->>U: redirect to OTT callback with authorization code
    U->>OTT: deliver code
    OTT->>GW: POST /oidc/token (code + code_verifier)
    GW-->>OTT: id_token + access_token
    OTT->>GW: GET /oidc/userinfo (with access_token)
    GW-->>OTT: { sub, msisdn, name }
    OTT->>OTT: lookup entitlement by subscriberId
    OTT-->>U: grant access / stream


%% ============================================================
%% 6. ENTITLEMENT PROVISIONING  (Fulfilment Service → OTT)
%% ============================================================
sequenceDiagram
    participant SG as Order Saga
    participant FUL as Fulfilment Service
    participant OTT as OTT Admin API
    participant TS as Token Server (Gateway)

    SG->>FUL: fulfil step — FulfilOrderCommand (DIGITAL_SUBSCRIPTION)
    Note over FUL: dispatch by productType → OTT provisioning
    FUL->>TS: POST /oidc/token (client_credentials, scope=ott:provision)
    TS-->>FUL: access_token (short-lived, 5 min)
    FUL->>OTT: POST /admin/entitlements (Bearer token) {subscriberId, offerCode, validFrom, validUntil, sagaId}
    OTT->>OTT: upsert entitlement (idempotent on sagaId)
    OTT-->>FUL: 201 Created {externalRef}
    FUL-->>SG: OrderFulfilled {externalRef}
    Note over SG: externalRef stamped onto OrderCompleted
