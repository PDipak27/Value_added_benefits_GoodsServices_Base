{
  "realm": "vab",
  "enabled": true,
  "displayName": "VA-BAGS",
  "sslRequired": "none",
  "registrationAllowed": false,
  "accessTokenLifespan": 3600,
  "clientScopes": [
    {
      "name": "ott:provision",
      "protocol": "openid-connect",
      "description": "Permission to provision / revoke OTT entitlements (machine-to-machine).",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "ott-service-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "ott-service",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "vab-provisioning",
      "name": "VA-BAGS provisioning (client-credentials, §A-1/A-4)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "vab-provisioning-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "defaultClientScopes": ["ott:provision"],
      "optionalClientScopes": []
    },
    {
      "clientId": "vab-ott",
      "name": "OTT relying party (Authorization Code + PKCE, §A-2)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:8087/*"],
      "webOrigins": ["http://localhost:8087"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "subscriberId",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "subscriberId",
            "claim.name": "subscriberId",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "usermodel.realmRoleMapping.rolePrefix": "",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false"
          }
        }
      ]
    }
  ],
  "roles": {
    "realm": [
      { "name": "vab-admin", "description": "Back-office admin — order re-drive, manual complete, entitlement revoke, ops search (§A-3/A5)." }
    ]
  },
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "email": "alice@example.com",
      "firstName": "Alice",
      "lastName": "Subscriber",
      "emailVerified": true,
      "attributes": { "subscriberId": ["sub-alice"] },
      "credentials": [
        { "type": "password", "value": "alice", "temporary": false }
      ]
    },
    {
      "username": "vabadmin",
      "enabled": true,
      "email": "admin@example.com",
      "firstName": "VA-BAGS",
      "lastName": "Admin",
      "emailVerified": true,
      "attributes": { "subscriberId": ["sub-admin"] },
      "credentials": [
        { "type": "password", "value": "vabadmin", "temporary": false }
      ],
      "realmRoles": ["vab-admin"]
    }
  ]
}
