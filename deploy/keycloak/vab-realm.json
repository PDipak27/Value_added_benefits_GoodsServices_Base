{
  "realm": "vab",
  "enabled": true,
  "displayName": "VA-BAGS",
  "sslRequired": "none",
  "registrationAllowed": false,
  "clientScopes": [
    {
      "name": "ott:provision",
      "protocol": "openid-connect",
      "description": "Permission to provision / revoke OTT entitlements (machine-to-machine).",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "ott-service-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "ott-service",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "vab-provisioning",
      "name": "VA-BAGS provisioning (client-credentials, §A-1/A-4)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "vab-provisioning-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "defaultClientScopes": ["ott:provision"],
      "optionalClientScopes": []
    },
    {
      "clientId": "vab-ott",
      "name": "OTT relying party (Authorization Code + PKCE, §A-2)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:8087/*"],
      "webOrigins": ["http://localhost:8087"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "subscriberId",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "subscriberId",
            "claim.name": "subscriberId",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "email": "alice@example.com",
      "firstName": "Alice",
      "lastName": "Subscriber",
      "emailVerified": true,
      "attributes": { "subscriberId": ["sub-alice"] },
      "credentials": [
        { "type": "password", "value": "alice", "temporary": false }
      ]
    }
  ]
}
